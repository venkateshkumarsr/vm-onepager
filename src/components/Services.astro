---
const services = [
  {
    title: 'Custom WordPress Website Development',
    description:
      'Fast, responsive, SEO-friendly websites built from Figma designs to full production builds.',
    features: [
      'Figma to WordPress',
      'Custom Development',
      'Elementor',
      'Landing Pages',
      'WooCommerce',
      'Responsive Design',
    ],
  },
  {
    title: 'Website Maintenance & Support',
    description:
      'Ongoing updates, troubleshooting, backups, and training so your site stays healthy and up to date.',
    features: [
      'Core / Theme / Plugin Updates',
      'Maintenance Plans',
      'Backup & Recovery',
      'Training',
      'Monthly Reports',
    ],
  },
  {
    title: 'Website Optimization & Security',
    description:
      'Improve speed, search visibility, and protect your site with hardening and malware removal.',
    features: [
      'Speed Optimization',
      'Core Web Vitals',
      'SEO',
      'Security Hardening',
      'Malware Removal',
    ],
  },
  {
    title: 'Website Redesign & Migration',
    description:
      'Modernize your existing site or move it to a new host with minimal downtime.',
    features: [
      'Redesign',
      'UI / UX',
      'Migration',
      'Hosting Transfers',
      'Staging to Live',
    ],
  },
];
---

<section class="services" id="services" aria-labelledby="services-heading">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">Services</span>
      <h2 id="services-heading">
        Complete Services for Every Stage of Your Website
      </h2>
    </div>

    <div class="grid">
      {services.map(({ title, description, features }) => (
        <article class="card">
          <h3 class="card-title">{title}</h3>
          <p class="card-desc">{description}</p>
          <ul class="feature-list" role="list">
            {features.map(f => <li>{f}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    padding-block: var(--space-3xl);
    background-color: var(--color-bg);
  }

  .container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  /* Section header */
  .section-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .eyebrow {
    font-size: var(--fs-body);
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  h2 {
    font-size: var(--fs-h2);
    font-weight: 800;
    line-height: 1.2;
    color: var(--color-text);
    max-width: 600px;
  }

  /* Grid */
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  /* Card */
  .card {
    background-color: var(--color-card-bg);
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .card-title {
    font-size: var(--fs-h4);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
  }

  .card-desc {
    font-size: var(--fs-body);
    color: var(--color-muted);
    line-height: 1.65;
  }

  /* Feature list */
  .feature-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    margin-top: auto;
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-border);
  }

  .feature-list li {
    font-size: var(--fs-body);
    color: var(--color-text);
    padding-left: var(--space-lg);
    position: relative;
  }

  .feature-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 700;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
