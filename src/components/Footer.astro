---
const policyLinks = [
  { label: 'Privacy',       href: 'https://virtualmind.services/privacy-policy/' },
  { label: 'Terms',         href: 'https://virtualmind.services/terms-and-conditions/' },
  { label: 'Cookie',        href: 'https://virtualmind.services/cookie-policy/' },
  { label: 'Disclaimer',    href: 'https://virtualmind.services/disclaimer/' },
  { label: 'Refund',        href: 'https://virtualmind.services/refund-policy/' },
  { label: 'Accessibility', href: 'https://virtualmind.services/accessibility-statement/' },
];
---

<footer class="site-footer">
  <div class="inner">
    <p class="copyright">© 2009–2026 VirtualMind Services</p>
    <nav aria-label="Footer policy links">
      <ul class="policy-links" role="list">
        {policyLinks.map(({ label, href }) => (
          <li>
            <a href={href} target="_blank" rel="noopener noreferrer">{label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-text);
    padding-block: var(--space-xl);
  }

  .inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--space-lg);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .copyright {
    font-size: var(--fs-body);
    color: var(--color-border);
  }

  .policy-links {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .policy-links a {
    font-size: var(--fs-body);
    color: var(--color-border);
    text-decoration: none;
    transition: color 0.15s;
  }

  .policy-links a:hover {
    color: #fff;
  }

  @media (max-width: 768px) {
    .inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
