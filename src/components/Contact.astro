---
const links = [
  {
    label: 'Email',
    href: 'mailto:venkat@virtualmind.services',
    display: 'venkat@virtualmind.services',
  },
  {
    label: 'WhatsApp',
    href: 'https://wa.me/+919916598295',
    display: '+91 99165 98295',
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/venkatesh-kumar-s-r-945b8821/',
    display: 'linkedin.com/in/venkatesh-kumar-s-r',
  },
];
---

<section class="contact" id="contact" aria-labelledby="contact-heading">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">Let's Work Together</span>
      <h2 id="contact-heading">Tell Us About Your Website Project</h2>
      <p class="intro">
        Whether you need website development, Figma conversion, a redesign, or
        ongoing maintenance, we're here to help. Share your project details and
        we'll get back to you within one business day.
      </p>
    </div>

    <div class="columns">
      <!-- Left: ways to connect -->
      <div class="connect">
        <h3 class="connect-title">Ways to Connect</h3>

        <ul class="meta-list" role="list">
          <li>
            <span class="meta-label">Agency</span>
            <span class="meta-value">VirtualMind Services</span>
          </li>
          <li>
            <span class="meta-label">Location</span>
            <span class="meta-value">Electronic City, Bangalore (Bengaluru), India</span>
          </li>
          <li>
            <span class="meta-label">Response Time</span>
            <span class="meta-value">Typically within 24 hours</span>
          </li>
        </ul>

        <ul class="link-list" role="list">
          {links.map(({ label, href, display }) => (
            <li>
              <span class="link-label">{label}</span>
              <a href={href} class="connect-link" target={href.startsWith('mailto') ? undefined : '_blank'} rel="noopener noreferrer">
                {display}
              </a>
            </li>
          ))}
        </ul>

        <a
          href="https://virtualmind.services/book-a-free-consultation/"
          class="consult-btn"
          target="_blank"
          rel="noopener noreferrer"
        >
          Book a Free Consultation
        </a>
      </div>

      <!-- Right: contact form -->
      <form
        class="form"
        name="contact"
        method="POST"
        data-netlify="true"
        novalidate
      >
        <input type="hidden" name="form-name" value="contact" />

        <div class="field">
          <label for="name">Name</label>
          <input id="name" type="text" name="name" required autocomplete="name" />
        </div>

        <div class="field">
          <label for="email">Email</label>
          <input id="email" type="email" name="email" required autocomplete="email" />
        </div>

        <div class="field">
          <label for="website">
            Website URL
            <span class="optional">(optional)</span>
          </label>
          <input id="website" type="url" name="website" autocomplete="url" />
        </div>

        <div class="field">
          <label for="details">Project Details</label>
          <textarea id="details" name="details" rows="5" required></textarea>
        </div>

        <button type="submit" class="submit-btn">Send Message</button>
      </form>
    </div>
  </div>
</section>

<style>
  .contact {
    padding-block: var(--space-3xl);
    background-color: var(--color-bg);
  }

  .container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .section-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .eyebrow {
    font-size: var(--fs-body);
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  h2 {
    font-size: var(--fs-h2);
    font-weight: 800;
    line-height: 1.2;
    color: var(--color-text);
    max-width: 640px;
  }

  .intro {
    font-size: var(--fs-lead);
    color: var(--color-muted);
    line-height: 1.7;
    max-width: 680px;
  }

  /* Two-column layout */
  .columns {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  /* Left column */
  .connect {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .connect-title {
    font-size: var(--fs-h4);
    font-weight: 700;
    color: var(--color-text);
  }

  .meta-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .meta-list li {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .meta-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
  }

  .meta-value {
    font-size: var(--fs-body);
    color: var(--color-text);
  }

  .link-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-border);
  }

  .link-list li {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .link-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
  }

  .connect-link {
    font-size: var(--fs-body);
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
    word-break: break-all;
  }

  .connect-link:hover {
    text-decoration: underline;
  }

  .consult-btn {
    display: inline-block;
    padding: var(--space-md) var(--space-xl);
    background-color: var(--color-primary);
    color: #fff;
    font-size: var(--fs-body);
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--radius);
    transition: opacity 0.15s;
    text-align: center;
  }

  .consult-btn:hover {
    opacity: 0.88;
  }

  /* Form */
  .form {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  label {
    font-size: var(--fs-body);
    font-weight: 600;
    color: var(--color-text);
  }

  .optional {
    font-weight: 400;
    color: var(--color-muted);
    font-size: 0.875em;
    margin-left: var(--space-xs);
  }

  input,
  textarea {
    width: 100%;
    padding: var(--space-md);
    font-size: var(--fs-body);
    font-family: inherit;
    color: var(--color-text);
    background-color: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  input:focus,
  textarea:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 15%, transparent);
  }

  textarea {
    resize: vertical;
    min-height: 8rem;
  }

  .submit-btn {
    align-self: flex-start;
    padding: var(--space-md) var(--space-xl);
    background-color: var(--color-primary);
    color: #fff;
    font-size: var(--fs-body);
    font-weight: 600;
    font-family: inherit;
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .submit-btn:hover {
    opacity: 0.88;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .columns {
      grid-template-columns: 1fr;
    }

    .submit-btn {
      align-self: stretch;
      text-align: center;
    }
  }
</style>
