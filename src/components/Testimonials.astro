---
const testimonials = [
  {
    quote:
      'Venkat has been working with us for quite a while on multiple site development projects. He is exceptionally good to work with as the work is done well and the communication is excellent. Would highly recommend!',
    name: 'Chad LaVallie',
    country: 'USA',
  },
  {
    quote:
      'Pavithra did an amazing job building a website for my client. She has an eye for detail and communication was clear. Would highly recommend her to anyone.',
    name: 'Mark Spence',
    country: 'Spain',
  },
  {
    quote:
      'Exceptionally professional, competent, and prompt. Extremely happy with the work done. If I could give more than 5 stars, I would unhesitatingly give it.',
    name: 'Srini Kumar',
    country: 'USA',
  },
  {
    quote:
      'Pavithra is a fantastic professional to work with. She is highly skilled in her work. Her communication is clear, and her attention to detail is thorough. I have recommended her to others.',
    name: 'Lorie Poston',
    country: 'USA',
  },
  {
    quote:
      'A pleasure to work with. Very quick to respond, performed excellent work, completed project quickly, and all around a great experience. Would love to work with again!',
    name: 'Dan Westbrok',
    country: 'USA',
  },
  {
    quote:
      'This is one of the best freelancers I worked with and will do again going forward!',
    name: 'Robert Hollis',
    country: 'USA',
  },
];
---

<section class="testimonials" id="testimonials" aria-labelledby="testimonials-heading">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">What Our Clients Say</span>
      <h2 id="testimonials-heading">
        Trusted by Clients Worldwide for Reliable Website Development
      </h2>
      <div class="rating" aria-label="5 out of 5 stars, based on 318 reviews on Upwork">
        <span class="stars" aria-hidden="true">★★★★★</span>
        <span class="rating-text">5/5 — Based on 318 reviews on Upwork</span>
      </div>
    </div>

    <!-- Scroll-snap track -->
    <div class="carousel-track" aria-label="Testimonials carousel">
      {testimonials.map(({ quote, name, country }, i) => (
        <article class="card" aria-label={`Testimonial ${i + 1} of ${testimonials.length}`}>
          <span class="deco-quote" aria-hidden="true">"</span>
          <blockquote class="quote">
            <p>{quote}</p>
          </blockquote>
          <footer class="card-footer">
            <span class="client-name">{name}</span>
            <span class="client-country">{country}</span>
          </footer>
        </article>
      ))}
    </div>

    <!-- Controls: prev · dots · next -->
    <div class="carousel-controls">
      <button class="carousel-prev" aria-label="Previous testimonials">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="dots" role="group" aria-label="Testimonial navigation">
        {testimonials.map((_, i) => (
          <button
            class={`dot${i === 0 ? ' active' : ''}`}
            aria-label={`Go to testimonial ${i + 1}`}
            aria-pressed={i === 0 ? 'true' : 'false'}
          />
        ))}
      </div>

      <button class="carousel-next" aria-label="Next testimonials">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
(function () {
  const section = document.querySelector('.testimonials') as HTMLElement;
  if (!section) return;

  const track    = section.querySelector('.carousel-track') as HTMLElement;
  const cards    = Array.from(track.querySelectorAll('.card')) as HTMLElement[];
  const dots     = Array.from(section.querySelectorAll('.dot')) as HTMLButtonElement[];
  const prevBtn  = section.querySelector('.carousel-prev') as HTMLButtonElement;
  const nextBtn  = section.querySelector('.carousel-next') as HTMLButtonElement;
  const count    = cards.length;

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const behavior: ScrollBehavior = prefersReduced ? 'auto' : 'smooth';

  // step = one card width + the gap between cards, both measured live so
  // it stays correct after resize (cards use % widths via calc())
  function getStep(): number {
    const gap = parseFloat(getComputedStyle(track).columnGap) || 0;
    return cards[0].offsetWidth + gap;
  }

  // True when the last card is fully in view (1px tolerance for sub-pixel rounding)
  function isAtEnd(): boolean {
    return track.scrollLeft + track.clientWidth >= track.scrollWidth - 1;
  }

  // Map current scroll position to the nearest card index, clamped to [0, count-1]
  function getActiveIdx(): number {
    const step = getStep();
    if (!step) return 0;
    return Math.max(0, Math.min(count - 1, Math.round(track.scrollLeft / step)));
  }

  // Scroll to a specific card using step-based positioning (not offsetLeft,
  // which is document-relative and would overshoot the track's maxScrollLeft)
  function scrollToCard(idx: number) {
    track.scrollTo({ left: idx * getStep(), behavior });
  }

  // Update dot active state
  function updateDots() {
    const idx = getActiveIdx();
    dots.forEach((dot, i) => {
      const active = i === idx;
      dot.classList.toggle('active', active);
      dot.setAttribute('aria-pressed', String(active));
    });
  }

  // Throttle dot updates to one rAF per scroll event burst
  let rafId: number | null = null;
  track.addEventListener('scroll', () => {
    if (rafId) return;
    rafId = requestAnimationFrame(() => { updateDots(); rafId = null; });
  }, { passive: true });

  // Arrow buttons — use scrollBy so the browser handles sub-pixel snap alignment;
  // detect end/start with isAtEnd() / scrollLeft check rather than an index counter
  prevBtn.addEventListener('click', () => {
    stopAutoplay();
    if (track.scrollLeft <= 1) {
      // At start: loop to the last page (browser clamps to maxScrollLeft)
      track.scrollTo({ left: track.scrollWidth, behavior });
    } else {
      track.scrollBy({ left: -getStep(), behavior });
    }
  });

  nextBtn.addEventListener('click', () => {
    stopAutoplay();
    if (isAtEnd()) {
      scrollToCard(0);
    } else {
      track.scrollBy({ left: getStep(), behavior });
    }
  });

  // Dot buttons
  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => { stopAutoplay(); scrollToCard(i); });
  });

  // Stop autoplay on any direct pointer interaction with the track (touch/drag)
  track.addEventListener('pointerdown', stopAutoplay, { passive: true });

  // Autoplay — disabled entirely when prefers-reduced-motion is set
  let timer: ReturnType<typeof setInterval> | null = null;
  let stopped = false;

  function startAutoplay() {
    if (prefersReduced || stopped || timer) return;
    timer = setInterval(() => {
      // Loop back to the start only once the last card is fully visible
      if (isAtEnd()) {
        scrollToCard(0);
      } else {
        track.scrollBy({ left: getStep(), behavior });
      }
    }, 5000);
  }

  function pauseAutoplay() {
    if (!timer) return;
    clearInterval(timer);
    timer = null;
  }

  function stopAutoplay() {
    if (stopped) return;
    stopped = true;
    pauseAutoplay();
  }

  // Pause on hover / focus; resume on leave / blur (unless permanently stopped)
  section.addEventListener('mouseenter', pauseAutoplay);
  section.addEventListener('mouseleave', () => { if (!stopped) startAutoplay(); });
  section.addEventListener('focusin',    pauseAutoplay);
  section.addEventListener('focusout',   () => { if (!stopped) startAutoplay(); });

  updateDots();
  startAutoplay();
})();
</script>

<style>
  .testimonials {
    padding-block: var(--space-3xl);
    background-color: var(--color-bg);
  }

  .container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .section-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .eyebrow {
    font-size: var(--fs-body);
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  h2 {
    font-size: var(--fs-h2);
    font-weight: 800;
    line-height: 1.2;
    color: var(--color-text);
    max-width: 680px;
  }

  .rating {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }

  .stars {
    color: var(--color-accent);
    font-size: var(--fs-h4);
    line-height: 1;
    letter-spacing: 2px;
  }

  .rating-text {
    font-size: var(--fs-body);
    color: var(--color-muted);
    font-weight: 500;
  }

  /* ── Carousel track ── */
  .carousel-track {
    display: flex;
    gap: var(--space-lg);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-padding-left: 0;
    /* hide scrollbar across browsers */
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  /* ── Cards ── */
  .card {
    /* desktop: 3 visible */
    flex-shrink: 0;
    width: calc((100% - 2 * var(--space-lg)) / 3);
    scroll-snap-align: start;
    background-color: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    position: relative;
    overflow: hidden;
  }

  .deco-quote {
    position: absolute;
    top: var(--space-md);
    right: var(--space-lg);
    font-size: 5rem;
    line-height: 1;
    color: var(--color-border);
    font-family: Georgia, serif;
    pointer-events: none;
    user-select: none;
  }

  .quote {
    flex: 1;
  }

  .quote p {
    font-size: var(--fs-body);
    color: var(--color-text);
    line-height: 1.7;
  }

  .card-footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  .client-name {
    font-size: var(--fs-body);
    font-weight: 700;
    color: var(--color-text);
  }

  .client-country {
    font-size: var(--fs-body);
    color: var(--color-muted);
  }

  /* ── Controls ── */
  .carousel-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
  }

  .carousel-prev,
  .carousel-next {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    background-color: var(--color-card-bg);
    color: var(--color-text);
    cursor: pointer;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s;
    flex-shrink: 0;
  }

  .carousel-prev:hover,
  .carousel-next:hover {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }

  /* Dots */
  .dots {
    display: flex;
    gap: var(--space-sm);
    align-items: center;
  }

  .dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    border: none;
    background-color: var(--color-border);
    cursor: pointer;
    padding: 0;
    transition: background-color 0.2s, transform 0.2s;
  }

  .dot.active {
    background-color: var(--color-primary);
    transform: scale(1.4);
  }

  /* ── Responsive card widths ── */

  /* tablet: 2 cards */
  @media (max-width: 1024px) {
    .card {
      width: calc((100% - 1 * var(--space-lg)) / 2);
    }
  }

  /* mobile: 1 card full-width */
  @media (max-width: 600px) {
    .card {
      width: 100%;
    }
  }
</style>
