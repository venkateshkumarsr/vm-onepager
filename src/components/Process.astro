---
const steps = [
  {
    title: 'Discovery & Planning',
    description:
      'We learn about your business goals, target audience, and technical requirements to create a clear project roadmap.',
  },
  {
    title: 'Design Review',
    description:
      'We analyze your Figma files or existing design to ensure every section is ready for pixel-perfect development.',
  },
  {
    title: 'Custom Development',
    description:
      'We convert approved designs into clean, scalable websites using best coding practices.',
  },
  {
    title: 'Performance Optimization',
    description:
      'We optimize speed, responsiveness, and SEO structure to help your website load quickly and rank better.',
  },
  {
    title: 'Testing & Quality Assurance',
    description:
      'We test across devices and browsers to ensure everything works smoothly and reliably.',
  },
  {
    title: 'Launch & Ongoing Support',
    description:
      'We deploy your website and provide maintenance, updates, and support.',
  },
];
---

<section class="process" aria-labelledby="process-heading">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">Our Process</span>
      <h2 id="process-heading">
        How We Turn Your Ideas into a High-Performing Website
      </h2>
    </div>

    <div class="grid">
      {steps.map(({ title, description }, i) => (
        <div class="step">
          <div class="step-badge" aria-hidden="true">{i + 1}</div>
          <h3 class="step-title">{title}</h3>
          <p class="step-desc">{description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process {
    padding-block: var(--space-3xl);
    background-color: var(--color-card-bg);
  }

  .container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .section-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .eyebrow {
    font-size: var(--fs-body);
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  h2 {
    font-size: var(--fs-h2);
    font-weight: 800;
    line-height: 1.2;
    color: var(--color-text);
    max-width: 600px;
  }

  /* Grid — 3 columns desktop */
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  /* Step */
  .step {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  /* Circular number badge */
  .step-badge {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    background-color: var(--color-primary);
    color: #fff;
    font-size: var(--fs-h4);
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .step-title {
    font-size: var(--fs-h4);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
  }

  .step-desc {
    font-size: var(--fs-body);
    color: var(--color-muted);
    line-height: 1.65;
  }

  /* Mobile: 1 column */
  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
